ENVIRONMENT=development
DATABASE_URL=sqlite+aiosqlite:///./geoai.db
JWT_SECRET_KEY=change-this-to-a-long-random-secret-key-before-production
FRONTEND_ORIGIN=http://localhost:5173

# LLM — switch between "mock" and "ollama"
LLM_PROVIDER=ollama
LLM_MODEL_NAME=qwen2.5-coder:1.5b
OLLAMA_BASE_URL=http://localhost:11434
LLM_TIMEOUT_SECONDS=60
